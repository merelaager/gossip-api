// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model GeneralInfo {
  id    Int    @id @default(autoincrement()) @db.UnsignedInt
  key   String @unique @db.VarChar(255)
  value String @db.VarChar(255)

  @@map("general_info")
}

model User {
  id            String       @id @default(uuid())
  username      String       @unique
  password      String
  name          String?
  isDeleted     Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  posts         Post[]       @relation("Posts")
  approvedPosts Post[]       @relation("ApprovedPosts")
  role          Role         @default(USER)
  shift         Int
  code          InviteCode?  @relation(fields: [codeId], references: [id])
  codeId        String?      @unique
  likes         PostLike[]   @relation("UserLikes")
  comments      Comment[]    @relation("UserComments")
  appleTokens   AppleToken[]
}

model AppleToken {
  id        String    @id @db.VarChar(255)
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  tokenType TokenType @default(PROD)
  createdAt DateTime  @default(now()) @db.DateTime(0)
}

model Post {
  id         String     @id @default(uuid())
  title      String
  content    String?    @db.Text
  imageId    String?
  published  Boolean    @default(false)
  hidden     Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  author     User       @relation("Posts", fields: [authorId], references: [id], onDelete: Cascade)
  authorId   String
  approvedBy User?      @relation("ApprovedPosts", fields: [approverId], references: [id])
  approverId String?
  shift      Int
  likes      PostLike[] @relation("PostLikes")
  comments   Comment[]  @relation("PostComments")
}

model Comment {
  id        String   @id @default(uuid())
  content   String   @db.Text
  hidden    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      Post     @relation("PostComments", fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  author    User     @relation("UserComments", fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String

  @@index([postId, createdAt])
}

model PostLike {
  post      Post     @relation("PostLikes", fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  user      User     @relation("UserLikes", fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([postId, userId])
}

model InviteCode {
  id        String   @id
  used      Boolean  @default(false)
  name      String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shift     Int
  usedBy    User?
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String   @db.Text
  expiresAt DateTime @db.DateTime(0)
  createdAt DateTime @default(now()) @db.DateTime(0)

  @@map("sessions")
}

enum Role {
  USER
  ADMIN
  MOD
  READER
}

enum TokenType {
  DEV
  PROD
}
